# Apache Kafka Event Streaming Endpoint
KAFKA_BROKER=your-broker-url.aivencloud.com:12345

# SSL/TLS Configuration (Replace with actual multi-line certificates)
KAFKA_CA_PEM="-----BEGIN CERTIFICATE-----\nYOUR_CA_CONTENT\n-----END CERTIFICATE-----"
KAFKA_CERT_PEM="-----BEGIN CERTIFICATE-----\nYOUR_CERT_CONTENT\n-----END CERTIFICATE-----"
KAFKA_KEY_PEM="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT\n-----END PRIVATE KEY-----"

# Schema Registry (Karapace)
SCHEMA_REGISTRY_URL=https://your-schema-registry-uri.aivencloud.com:PORT
SCHEMA_REGISTRY_USERNAME=avnadmin
SCHEMA_REGISTRY_PASSWORD=your-registry-password

# Server
PORT=3001
