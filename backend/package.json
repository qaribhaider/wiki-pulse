{
	"name": "wiki-pulse",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"engines": {
		"node": ">=22.0.0"
	},
	"license": "ISC",
	"type": "module",
	"scripts": {
		"start": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' KAFKAJS_NO_PARTITIONER_WARNING=1 ts-node src/server/index.ts",
		"producer": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' KAFKAJS_NO_PARTITIONER_WARNING=1 ts-node src/kafka/producer.ts",
		"producer:mock": "WIKIMEDIA_STREAM_URL=http://localhost:8080/v2/stream/recentchange NODE_OPTIONS='--loader ts-node/esm --no-warnings' KAFKAJS_NO_PARTITIONER_WARNING=1 ts-node src/kafka/producer.ts",
		"aggregator": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' KAFKAJS_NO_PARTITIONER_WARNING=1 ts-node src/kafka/aggregator.ts",
		"alerts": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' KAFKAJS_NO_PARTITIONER_WARNING=1 ts-node src/kafka/alerts.ts",
		"setup": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node src/kafka/setup.ts",
		"mock-server": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node src/tests/mock-sse.ts",
		"dev": "concurrently \"npm run start\" \"npm run producer\" \"npm run aggregator\" \"npm run alerts\"",
		"build": "tsc",
		"start:prod": "NODE_ENV=production node dist/server/index.js",
		"producer:prod": "NODE_ENV=production node dist/kafka/producer.js",
		"aggregator:prod": "NODE_ENV=production node dist/kafka/aggregator.js",
		"alerts:prod": "NODE_ENV=production node dist/kafka/alerts.js",
		"start:all:prod": "concurrently \"npm run start:prod\" \"npm run producer:prod\" \"npm run aggregator:prod\" \"npm run alerts:prod\"",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"lint": "biome check ./src",
		"format": "biome check --write ./src"
	},
	"keywords": [],
	"author": "",
	"dependencies": {
		"@kafkajs/confluent-schema-registry": "^4.0.8",
		"avsc": "^5.7.9",
		"concurrently": "^9.2.1",
		"dotenv": "^17.4.0",
		"eventsource": "^4.1.0",
		"express": "^5.2.1",
		"helmet": "^4.6.0",
		"kafkajs": "^2.2.4",
		"p-retry": "^8.0.0",
		"pino": "^10.3.1",
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@playwright/test": "^1.59.1",
		"@types/eventsource": "^1.1.15",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.5.2",
		"@types/ws": "^8.18.1",
		"pino-pretty": "^13.1.3",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
